  end

  subgraph async["Async & UX"]
    ALT[Alerting engine]
    RUL[Rule store]
    NOT[Notification router]
    DASH[Dashboard API]
  end

  A1 --> GW
  A2 --> GW
  A3 --> GW
  GW --> ING
  ING --> WAL
