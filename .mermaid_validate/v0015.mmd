flowchart TD
    subgraph Ingestion
        DB[(Databases)] --> INGEST
        API[APIs] --> INGEST
        LOG[Logs] --> INGEST
        IOT[IoT Devices] --> INGEST[Ingestion Layer<br/>Kafka, Kinesis, Flume]
